# MongoDB Secrets
# Este archivo NO se sube a Git - solo para uso local
# Usa el script setup-secrets.sh para crear los secretos en AWS

# Development environment
DEV_MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority

# Staging environment
STAGING_MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority

# Production environment
# PROD_MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
